{
  "name": "temper",
  "private": true,
  "version": "0.1.0",
  "description": "Repo-local operating system for AI-assisted game teams",
  "license": "MIT",
  "type": "module",
  "bin": {
    "temper": "./packages/cli/bin/temper.mjs"
  },
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "postinstall": "node packages/cli/bin/postinstall.mjs",
    "temper": "node packages/cli/bin/temper.mjs",
    "doctor": "node packages/cli/bin/temper.mjs doctor",
    "derive": "node packages/cli/bin/temper.mjs derive",
    "test": "node --test packages/cli/test/*.test.mjs packages/mcp/test/*.test.mjs"
  }
}
